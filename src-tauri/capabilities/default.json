{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-text",
    "fs:allow-write-file",
    "fs:allow-download-write",
    "fs:allow-download-read",
    "os:allow-platform"
  ]
}
